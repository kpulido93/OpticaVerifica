# ===========================================
# OPTIMA VERIFICA - Environment Configuration
# ===========================================

# MySQL Database
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=neon_templaris
MYSQL_USER=optima_user
MYSQL_PASSWORD=your_secure_password_here
MYSQL_ROOT_PASSWORD=your_root_password_here

# Connection String (built from above or override directly)
# CONNECTION_STRING=Server=${MYSQL_HOST};Port=${MYSQL_PORT};Database=${MYSQL_DATABASE};User=${MYSQL_USER};Password=${MYSQL_PASSWORD};

# API Configuration
API_PORT=5000
API_ENVIRONMENT=Development

# Worker Configuration
WORKER_MAX_CONCURRENT_JOBS=5
WORKER_BATCH_SIZE=100
WORKER_MAX_IDS_PER_JOB=10000

# Authentication (Basic Auth for MVP)
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=change_this_admin_password
AUTH_OPERATOR_USER=operator
AUTH_OPERATOR_PASSWORD=change_this_operator_password
AUTH_READER_USER=reader
AUTH_READER_PASSWORD=change_this_reader_password

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=Optima Verifica

# Sigeinfo Provider (Future - NOT IMPLEMENTED)
SIGEINFO_ENABLED=false
SIGEINFO_SCHEDULE_START=08:00
SIGEINFO_SCHEDULE_END=18:00
SIGEINFO_TIMEZONE=America/Santo_Domingo

# Export Configuration
EXPORT_MAX_ROWS=100000
EXPORT_TEMP_PATH=/tmp/exports

# Logging
LOG_LEVEL=Information
