TZ=America/Santo_Domingo

# Basic Auth (roles)
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=change_me_admin_password
AUTH_OPERATOR_USER=operator
AUTH_OPERATOR_PASSWORD=change_me_operator_password
AUTH_READER_USER=reader
AUTH_READER_PASSWORD=change_me_reader_password

# MySQL (docker-compose)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=change_me_database_name
MYSQL_USER=change_me_database_user
MYSQL_PASSWORD=change_me_database_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# API / Frontend
API_PORT=5000
API_ENVIRONMENT=Development
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=Optima Verifica

# Worker
WORKER_MAX_CONCURRENT_JOBS=5
WORKER_BATCH_SIZE=100
WORKER_MAX_IDS_PER_JOB=10000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limit
RATE_LIMIT_PERMIT_LIMIT=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_QUEUE_LIMIT=0
